#!/usr/bin/env bash
#
# Build hl-server, stand up a tiny static server in front of the given log file so
# the backend has a publicly-fetchable URL to point at, run hl-server in the
# foreground, and open the viewer in the default browser with `?src=<log url>`.
#
# Ctrl-C / SIGTERM at any point kills both servers and cleans up the temporary
# directory used to expose the log file.
#
# Usage:
#   contrib/bin/serve <log-file> [server-port] [source-port]

set -euo pipefail

repo_root=$(cd "$(dirname "$0")/../.." && pwd)
cd "$repo_root"

log_path="${1:-}"
server_port="${2:-8080}"
source_port="${3:-}"

if [ -z "$log_path" ]; then
    echo "usage: $0 <log-file> [server-port] [source-port]" >&2
    exit 2
fi
if [ ! -f "$log_path" ]; then
    echo "error: log file not found: $log_path" >&2
    exit 1
fi

# Random high port for the source server when not overridden, so consecutive runs
# don't collide if one didn't exit cleanly.
if [ -z "$source_port" ]; then
    source_port=$(( 49152 + RANDOM % 16000 ))
fi

cargo build --release -p hl-server

# Expose the log file via a dedicated work dir so miniserve only sees that one
# file. The dir + symlink go away on exit so we don't leak temp state.
work_dir=$(mktemp -d -t hl-server-XXXXXX)
log_abs=$(cd "$(dirname "$log_path")" && pwd)/$(basename "$log_path")
name=$(basename "$log_abs")
ln -sfn "$log_abs" "$work_dir/$name"

src_url="http://127.0.0.1:${source_port}/${name}"
viewer_url="http://127.0.0.1:${server_port}/?src=${src_url}"

src_pid=""
srv_pid=""
cleanup() {
    [ -n "$srv_pid" ] && kill -INT "$srv_pid" 2>/dev/null || true
    [ -n "$src_pid" ] && kill -INT "$src_pid" 2>/dev/null || true
    [ -n "$srv_pid" ] && wait "$srv_pid" 2>/dev/null || true
    [ -n "$src_pid" ] && wait "$src_pid" 2>/dev/null || true
    rm -rf "$work_dir"
}
trap cleanup INT TERM EXIT

miniserve --port "$source_port" "$work_dir" >/dev/null 2>&1 &
src_pid=$!

# Wait for miniserve to accept connections so the viewer doesn't race the probe.
for _ in $(seq 1 60); do
    if curl -sf -o /dev/null --max-time 0.2 "http://127.0.0.1:${source_port}/" 2>/dev/null; then
        break
    fi
    sleep 0.1
done

echo "Opening $viewer_url"
if command -v open >/dev/null 2>&1; then
    ( sleep 0.5 && open "$viewer_url" ) &
elif command -v xdg-open >/dev/null 2>&1; then
    ( sleep 0.5 && xdg-open "$viewer_url" ) &
fi

# --allow-private because the source URL we just spun up resolves to 127.0.0.1,
# which the SSRF guard refuses by default.
./target/release/hl-server \
    --bind "127.0.0.1:${server_port}" \
    --www-dir crates/hl-server/www \
    --allow-private &
srv_pid=$!

wait "$srv_pid"
