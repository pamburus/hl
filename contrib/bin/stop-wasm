#!/usr/bin/env bash
#
# Stop a background hl-wasm viewer started via `serve-wasm`.
#
# Reads the PID from target/hl-wasm-serve.pid; sends SIGINT; removes the pidfile.
#
# Usage:
#   contrib/bin/stop-wasm

set -euo pipefail

repo_root=$(cd "$(dirname "$0")/../.." && pwd)
cd "$repo_root"

pidfile="target/hl-wasm-serve.pid"
if [ ! -f "$pidfile" ]; then
    echo "no pidfile at $pidfile — nothing to stop"
    exit 0
fi

pid=$(cat "$pidfile")
if kill -0 "$pid" 2>/dev/null; then
    kill -INT "$pid"
    echo "stopped pid $pid"
else
    echo "pid $pid not running; removing stale pidfile"
fi
rm -f "$pidfile"
